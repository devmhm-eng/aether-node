# Port the aether-node agent listens on
PORT=2096

# Secret key — the main Aether panel uses this to authenticate requests
# Generate with: openssl rand -hex 32
API_KEY=change_me_to_a_random_secret

# Path to the xray executable
XRAY_EXECUTABLE=/usr/local/bin/xray

# Path where aether-node writes the Xray config before (re)starting Xray
XRAY_CONFIG_PATH=/etc/xray/config.json

# Directory where Xray writes its log files (used by /api/logs)
XRAY_LOG_DIR=/var/log/xray

# How many log lines to tail per request
LOG_TAIL_LINES=200
